<Page
    x:Class="SteamEyaWinUI.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SteamEyaWinUI.Models"
    xmlns:loc="using:SteamEyaWinUI.Localization"
    NavigationCacheMode="Required">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="{x:Bind Strings.Get('History_Title'), Mode=OneWay}" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock
                    x:Name="HistorySummaryText"
                    Text="{x:Bind Strings.Get('History_Subtitle'), Mode=OneWay}"
                    Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <AutoSuggestBox
                x:Name="HistorySearchBox"
                Grid.Column="1"
                Width="240"
                VerticalAlignment="Center"
                PlaceholderText="{x:Bind Strings.Get('History_Search_Placeholder'), Mode=OneWay}"
                QueryIcon="Find"
                TextChanged="HistorySearchBox_TextChanged" />

            <Button
                x:Name="RefreshHistoryButton"
                Grid.Column="2"
                VerticalAlignment="Center"
                Click="RefreshHistoryButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="16" />
                    <TextBlock Text="{x:Bind Strings.Get('Common_Refresh'), Mode=OneWay}" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="ImportHistoryButton"
                        Click="ImportHistoryButton_Click"
                        ToolTipService.ToolTip="{x:Bind Strings.Get('History_Import_Tooltip'), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE77F;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('Common_Import'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="ClearInvalidAccountsButton"
                        Grid.Column="1"
                        Click="ClearInvalidAccountsButton_Click"
                        ToolTipService.ToolTip="{x:Bind Strings.Get('History_ClearInvalid_Tooltip'), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE894;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('History_ClearInvalid_Button'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="ClearHistoryButton"
                        Grid.Column="2"
                        Click="ClearHistoryButton_Click"
                        ToolTipService.ToolTip="{x:Bind Strings.Get('History_ClearAll_Tooltip'), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE75C;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('Common_Clear'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ListView
                    x:Name="HistoryAccountList"
                    Grid.Row="1"
                    SelectionMode="Single"
                    SelectionChanged="HistoryAccountList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SteamAccountHistoryItem">
                            <Grid
                                Background="Transparent"
                                PointerEntered="HistoryCard_PointerEntered"
                                PointerExited="HistoryCard_PointerExited">
                                <Border
                                    Padding="12"
                                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                                    BorderThickness="1"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Grid MinHeight="56" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <PersonPicture
                                            Width="48"
                                            Height="48"
                                            VerticalAlignment="Center"
                                            DisplayName="{x:Bind AccountTitle}"
                                            ProfilePicture="{x:Bind AvatarImage}" />

                                        <StackPanel
                                            Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                Text="{x:Bind AccountTitle}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Text="{x:Bind PersonaDisplayName}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Text="{x:Bind CooldownSummaryText}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Text="{x:Bind LastLoginCaptionText}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                            <Button
                                                Style="{StaticResource AccentButtonStyle}"
                                                Padding="9,7"
                                                Click="CardQuickLoginButton_Click"
                                                ToolTipService.ToolTip="{loc:Localize Key=History_Card_QuickLogin}">
                                                <FontIcon Glyph="&#xE8D4;" FontSize="14" />
                                            </Button>
                                            <Button
                                                Padding="9,7"
                                                Click="CardExportButton_Click"
                                                ToolTipService.ToolTip="{loc:Localize Key=History_Card_Copy}">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                            </Button>
                                            <Button
                                                Padding="9,7"
                                                Click="CardDeleteButton_Click"
                                                ToolTipService.ToolTip="{loc:Localize Key=History_Card_Delete}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- 选中：整卡黑框（高对比 ink 边框，参考主流多选样式） -->
                                <Border
                                    BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                                    IsHitTestVisible="False"
                                    Visibility="{x:Bind SelectionRingVisibility, Mode=OneWay}" />

                                <!-- 左上角 45° 角标勾选指示器（参考相册类多选）：悬停半透明角标作提示，
                                     选中实心 ink 三角 + 白色对勾；尖角随卡片圆角裁剪。
                                     用无 chrome 的 Button（而非 Tapped）以可靠阻止点勾选顺带选中整行（详情焦点）。 -->
                                <Button
                                    Width="30"
                                    Height="30"
                                    Margin="0"
                                    Padding="0"
                                    BorderThickness="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Click="HistoryCardCheck_Click"
                                    ToolTipService.ToolTip="{loc:Localize Key=Common_CheckToBatch}"
                                    Visibility="{x:Bind CheckIndicatorVisibility, Mode=OneWay}">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                    </Button.Resources>
                                    <Grid>
                                        <!-- 45° 角标三角：左上尖角按卡片圆角(8)用圆弧内建进几何，不做裁剪——
                                             Path 填充自带抗锯齿，斜边与圆角都平滑（裁剪边缘才会产生锯齿）。 -->
                                        <Path
                                            Data="M 8,0 L 30,0 L 0,30 L 0,8 A 8,8 0 0 1 8,0 Z"
                                            Stretch="None"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                            Opacity="0.35"
                                            Visibility="{x:Bind EmptyCheckCircleVisibility, Mode=OneWay}" />
                                        <Path
                                            Data="M 8,0 L 30,0 L 0,30 L 0,8 A 8,8 0 0 1 8,0 Z"
                                            Stretch="None"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                            Visibility="{x:Bind SelectionRingVisibility, Mode=OneWay}" />
                                        <!-- 白色对勾：悬停或选中都显示 -->
                                        <FontIcon
                                            Glyph="&#xE73E;"
                                            FontSize="11"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="4,3,0,0"
                                            Foreground="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                            Visibility="{x:Bind CheckIndicatorVisibility, Mode=OneWay}" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    x:Name="HistoryEmptyPanel"
                    Grid.Row="1"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <FontIcon
                        Glyph="&#xE81C;"
                        FontSize="40"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        x:Name="HistoryEmptyText"
                        Text="{x:Bind Strings.Get('History_Empty_Title'), Mode=OneWay}"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        x:Name="HistoryEmptyHintText"
                        Text="{x:Bind Strings.Get('History_Empty_Hint'), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- 批量操作栏：勾选任意卡片后浮现在列表底部，操作针对全部已勾选账号 -->
                <Border
                    x:Name="BatchActionBar"
                    Grid.Row="1"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,4"
                    Padding="14,10"
                    Visibility="Collapsed"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="BatchSelectionText"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{x:Bind Strings.Get('Common_Selected_Format'), Mode=OneWay}" />
                        <Button
                            x:Name="BatchClearButton"
                            Grid.Column="1"
                            Click="BatchClearButton_Click"
                            Content="{x:Bind Strings.Get('Common_ClearSelection'), Mode=OneWay}" />
                        <Button
                            x:Name="BatchExportButton"
                            Grid.Column="2"
                            Click="BatchExportButton_Click"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('History_BatchExport_Tooltip'), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock Text="{x:Bind Strings.Get('Common_BatchExport'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="BatchDeleteButton"
                            Grid.Column="3"
                            Click="BatchDeleteButton_Click"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('History_BatchDelete_Tooltip'), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="{x:Bind Strings.Get('Common_BatchDelete'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <PersonPicture
                                x:Name="HistoryDetailAvatar"
                                Width="92"
                                Height="92"
                                DisplayName="{x:Bind Strings.Get('History_Detail_Unselected'), Mode=OneWay}" />
                            <TextBlock
                                x:Name="HistoryDetailAccountNameText"
                                Text="{x:Bind Strings.Get('History_Detail_NoAccountSelected'), Mode=OneWay}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="HistoryDetailPersonaText"
                                Text="{x:Bind Strings.Get('History_Detail_ProfileNotSynced'), Mode=OneWay}"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <MenuFlyoutSeparator />

                        <Grid RowSpacing="10" ColumnSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Steam64" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailSteamIdText"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_Unparsed'), Mode=OneWay}"
                                IsTextSelectionEnabled="True"
                                Style="{StaticResource FieldValueTextStyle}" />

                            <TextBlock Grid.Row="1" Text="{x:Bind Strings.Get('History_Detail_Label_JwtExpires'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailTokenExpiresText"
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_Unparsed'), Mode=OneWay}"
                                Style="{StaticResource FieldValueTextStyle}" />

                            <TextBlock Grid.Row="2" Text="{x:Bind Strings.Get('History_Detail_Label_LastLogin'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailLastLoginText"
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_NoRecord'), Mode=OneWay}"
                                Style="{StaticResource FieldValueTextStyle}" />

                            <TextBlock Grid.Row="3" Text="{x:Bind Strings.Get('History_Detail_Label_CompetitiveScore'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailCompetitiveScoreText"
                                Grid.Row="3"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_Pending'), Mode=OneWay}"
                                Style="{StaticResource FieldValueTextStyle}" />

                            <TextBlock Grid.Row="4" Text="{x:Bind Strings.Get('History_Detail_Label_CsLevel'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailCsLevelText"
                                Grid.Row="4"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_Pending'), Mode=OneWay}"
                                Style="{StaticResource FieldValueTextStyle}" />

                            <TextBlock Grid.Row="5" Text="{x:Bind Strings.Get('History_Detail_Label_CooldownStatus'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailCooldownStatusText"
                                Grid.Row="5"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_Pending'), Mode=OneWay}"
                                Style="{StaticResource FieldValueTextStyle}" />

                            <TextBlock Grid.Row="6" Text="{x:Bind Strings.Get('History_Detail_Label_JwtAvailability'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock
                                x:Name="HistoryDetailAccountStatusText"
                                Grid.Row="6"
                                Grid.Column="1"
                                Text="{x:Bind Strings.Get('History_Detail_Pending'), Mode=OneWay}"
                                Style="{StaticResource FieldValueTextStyle}" />
                        </Grid>

                        <Button
                            x:Name="OneClickHistoryQueryButton"
                            HorizontalAlignment="Stretch"
                            Click="OneClickHistoryQueryButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9D9;" FontSize="16" />
                                <TextBlock Text="{x:Bind Strings.Get('Common_OneClickQuery'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>

                        <!-- 取消按钮仅忙碌时可见；UpdateControlsEnabled 不禁用它，busy 期间始终可点。 -->
                        <Button
                            x:Name="CancelHistoryQueryButton"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            Click="CancelHistoryQueryButton_Click"
                            ToolTipService.ToolTip="{x:Bind Strings.Get('History_CancelQuery_Tooltip'), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE711;" FontSize="16" />
                                <TextBlock Text="{x:Bind Strings.Get('Common_Cancel'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="UseHistoryAccountButton"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="UseHistoryAccountButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                                <TextBlock Text="{x:Bind Strings.Get('History_LoadToLogin_Button'), Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>

        <ContentDialog
            x:Name="ImportDialog"
            Title="{x:Bind Strings.Get('History_ImportDialog_Title'), Mode=OneWay}"
            PrimaryButtonText="{x:Bind Strings.Get('History_ImportDialog_Primary'), Mode=OneWay}"
            CloseButtonText="{x:Bind Strings.Get('Common_Cancel'), Mode=OneWay}"
            DefaultButton="Primary">
            <StackPanel Spacing="12" MinWidth="400">
                <TextBlock
                    x:Name="ImportDialogSummaryText"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ListView
                    x:Name="ImportDialogList"
                    MaxHeight="320"
                    SelectionMode="Multiple"
                    SelectionChanged="ImportDialogList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AccountImportEntry">
                            <StackPanel Spacing="2" Padding="0,6">
                                <TextBlock Text="{x:Bind AccountName}" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{x:Bind SummaryText}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind TokenSummaryText}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>

<Page
    x:Class="SteamEyaWinUI.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:SteamEyaWinUI.Services"
    NavigationCacheMode="Required">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
        Padding="32,24,32,16">
        <Grid ColumnSpacing="24" MaxWidth="1280" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="FormPanel" Spacing="20">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind Strings.Get('Login_Title'), Mode=OneWay}" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock
                        Text="{x:Bind Strings.Get('Login_Subtitle'), Mode=OneWay}"
                        Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>

                <SelectorBar x:Name="ModeSelector" SelectionChanged="ModeSelector_SelectionChanged">
                    <SelectorBarItem x:Name="ManualModeItem" Text="{x:Bind Strings.Get('Login_Mode_Manual'), Mode=OneWay}">
                        <SelectorBarItem.Icon>
                            <FontIcon Glyph="&#xE70F;" />
                        </SelectorBarItem.Icon>
                    </SelectorBarItem>
                    <SelectorBarItem x:Name="AutoModeItem" Text="{x:Bind Strings.Get('Login_Mode_Auto'), Mode=OneWay}">
                        <SelectorBarItem.Icon>
                            <FontIcon Glyph="&#xE945;" />
                        </SelectorBarItem.Icon>
                    </SelectorBarItem>
                </SelectorBar>

                <Border x:Name="ManualPanel" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{x:Bind Strings.Get('Login_Manual_Section'), Mode=OneWay}" Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBox
                            x:Name="AccountNameBox"
                            Header="{x:Bind Strings.Get('Login_Field_AccountName'), Mode=OneWay}"
                            PlaceholderText="{x:Bind Strings.Get('Login_Field_AccountName_Placeholder'), Mode=OneWay}"
                            IsSpellCheckEnabled="False"
                            TextChanged="ManualCredentialBox_TextChanged"
                            KeyDown="AccountNameBox_KeyDown" />

                        <TextBox
                            x:Name="EyaTokenBox"
                            Height="150"
                            Header="{x:Bind Strings.Get('Login_Field_EyaToken'), Mode=OneWay}"
                            PlaceholderText="{x:Bind Strings.Get('Login_Field_EyaToken_Placeholder'), Mode=OneWay}"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            IsSpellCheckEnabled="False"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            TextChanged="ManualCredentialBox_TextChanged" />
                    </StackPanel>
                </Border>

                <Border x:Name="AutoPanel" Style="{StaticResource CardBorderStyle}" Visibility="Collapsed">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{x:Bind Strings.Get('Login_Auto_Section'), Mode=OneWay}" Style="{StaticResource SectionTitleTextStyle}" />

                        <ComboBox
                            x:Name="UpstreamServerBox"
                            HorizontalAlignment="Stretch"
                            Header="{x:Bind Strings.Get('Login_Field_UpstreamServer'), Mode=OneWay}"
                            SelectionChanged="UpstreamServerBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="services:SteamUpstreamServer">
                                    <TextBlock Text="{x:Bind Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBox
                            x:Name="LicenseKeyBox"
                            Header="{x:Bind Strings.Get('Login_Field_LicenseKey'), Mode=OneWay}"
                            PlaceholderText="{x:Bind Strings.Get('Login_Field_LicenseKey_Placeholder'), Mode=OneWay}"
                            IsSpellCheckEnabled="False"
                            TextChanged="LicenseKeyBox_TextChanged"
                            KeyDown="LicenseKeyBox_KeyDown" />

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="ResolvedAccountBox"
                                Header="{x:Bind Strings.Get('Login_Field_ResolvedAccount'), Mode=OneWay}"
                                IsReadOnly="True"
                                PlaceholderText="{x:Bind Strings.Get('Login_Value_NotResolved'), Mode=OneWay}" />

                            <Button
                                x:Name="ResolveLicenseButton"
                                Grid.Column="1"
                                MinWidth="112"
                                VerticalAlignment="Bottom"
                                Click="ResolveLicenseButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="16" />
                                    <TextBlock Text="{x:Bind Strings.Get('Login_Btn_ResolveLicense'), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid RowSpacing="12" ColumnSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="ClearWorkshopButton"
                        HorizontalAlignment="Stretch"
                        Padding="0,10"
                        Click="ClearWorkshopButton_Click"
                        ToolTipService.ToolTip="{x:Bind Strings.Get('Login_Btn_ClearWorkshop_Tip'), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('Login_Btn_ClearWorkshop'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="LoginButton"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Padding="0,10"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="LoginButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8D4;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('Login_Btn_Login'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>

                    <!-- 一键装配（用“配装”页保存的预设 + 当前账号 token），取代原“装备 R8”。 -->
                    <Button
                        x:Name="ApplyLoadoutButton"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Stretch"
                        Padding="0,10"
                        Click="ApplyLoadoutButton_Click"
                        ToolTipService.ToolTip="{x:Bind Strings.Get('Login_Btn_ApplyLoadout_Tip'), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7C1;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('Login_Btn_ApplyLoadout'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- 取消按钮仅忙碌时可见；OnBusyChanged 不禁用它，busy 期间始终可点。 -->
                <Button
                    x:Name="CancelButton"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    Visibility="Collapsed"
                    Click="CancelButton_Click"
                    ToolTipService.ToolTip="{x:Bind Strings.Get('Login_Btn_Cancel_Tip'), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE711;" FontSize="16" />
                        <TextBlock Text="{x:Bind Strings.Get('Common_Cancel'), Mode=OneWay}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top">
                <StackPanel Spacing="14">
                    <TextBlock Text="{x:Bind Strings.Get('Login_AccountInfo_Section'), Mode=OneWay}" Style="{StaticResource SectionTitleTextStyle}" />

                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <PersonPicture
                            x:Name="AccountInfoAvatar"
                            Width="76"
                            Height="76" />
                        <TextBlock
                            x:Name="AccountInfoPersonaText"
                            HorizontalAlignment="Center"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <MenuFlyoutSeparator />

                    <Grid RowSpacing="12" ColumnSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Bind Strings.Get('Login_Label_UserName'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoUserText"
                            Grid.Column="1"
                            Style="{StaticResource FieldValueTextStyle}" />

                        <TextBlock Grid.Row="1" Text="Steam64" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoSteamIdText"
                            Grid.Row="1"
                            Grid.Column="1"
                            IsTextSelectionEnabled="True"
                            Style="{StaticResource FieldValueTextStyle}" />

                        <TextBlock Grid.Row="2" Text="{x:Bind Strings.Get('Login_Label_JwtExpires'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoExpiresText"
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource FieldValueTextStyle}" />

                        <TextBlock Grid.Row="3" Text="{x:Bind Strings.Get('Login_Label_Availability'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoAvailabilityText"
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource FieldValueTextStyle}" />

                        <TextBlock Grid.Row="4" Text="{x:Bind Strings.Get('Login_Label_PremierScore'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoPremierScoreText"
                            Grid.Row="4"
                            Grid.Column="1"
                            Style="{StaticResource FieldValueTextStyle}" />

                        <TextBlock Grid.Row="5" Text="{x:Bind Strings.Get('Login_Label_CsLevel'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoCsLevelText"
                            Grid.Row="5"
                            Grid.Column="1"
                            Style="{StaticResource FieldValueTextStyle}" />

                        <TextBlock Grid.Row="6" Text="{x:Bind Strings.Get('Login_Label_Cooldown'), Mode=OneWay}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock
                            x:Name="AccountInfoCooldownStatusText"
                            Grid.Row="6"
                            Grid.Column="1"
                            Style="{StaticResource FieldValueTextStyle}" />
                    </Grid>

                    <Button
                        x:Name="OneClickQueryButton"
                        HorizontalAlignment="Stretch"
                        Click="OneClickQueryButton_Click"
                        ToolTipService.ToolTip="{x:Bind Strings.Get('Login_Btn_OneClickQuery_Tip'), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D9;" FontSize="16" />
                            <TextBlock Text="{x:Bind Strings.Get('Common_OneClickQuery'), Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
